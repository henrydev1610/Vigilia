    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "set EXPO_NO_DOCTOR=1 && set NODE_OPTIONS=--max-old-space-size=4096 && expo start --lan --port 8081",
    "start:clean": "set EXPO_NO_DOCTOR=1 && set NODE_OPTIONS=--max-old-space-size=4096 && expo start -c --lan --port 8081",
    "start:clear": "set EXPO_NO_DOCTOR=1 && set NODE_OPTIONS=--max-old-space-size=4096 && expo start -c --lan --port 8081",
    "reset": "node scripts/reset.js && npm install",
    "generate:brand-assets": "node scripts/generate-brand-assets.js",
    "android": "set EXPO_NO_DOCTOR=1 && set NODE_OPTIONS=--max-old-space-size=4096 && expo run:android",
    "ios": "set EXPO_NO_DOCTOR=1 && set NODE_OPTIONS=--max-old-space-size=4096 && expo run:ios",
    "web": "set EXPO_NO_DOCTOR=1 && set NODE_OPTIONS=--max-old-space-size=4096 && expo start --web --max-workers 2",
    "typecheck": "tsc --noEmit"
  },

NODE_ENV=development
PORT=3334
# Em producao (Dokploy), use o hostname interno do servico Postgres (normalmente o nome do servico: postgres)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gasto_politico?schema=public
REDIS_URL=redis://redis:6379
ENABLE_REDIS=true
DB_HOST=postgres
DB_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
WAIT_TIMEOUT_SECONDS=90
WAIT_FOR_DB=true
WAIT_FOR_REDIS=true
RUN_MIGRATIONS=true
SEED=false
AUTO_CREATE_DATABASE=true
DB_CONNECT_MAX_RETRIES=8
DB_CONNECT_RETRY_DELAY_MS=2000
DB_REQUIRED_ON_START=true
MIGRATION_MAX_RETRIES=8
MIGRATION_RETRY_DELAY_SECONDS=3
START_ON_MIGRATION_FAILURE=false
START_ON_DEPENDENCY_FAILURE=false
DB_HOST_ALIASES=postgres,db
DATABASE_ADMIN_URL=postgresql://postgres:postgres@postgres:5432/postgres
JWT_ACCESS_SECRET=supersecretaccesskey_with_at_least_32_chars
JWT_REFRESH_SECRET=supersecretrefreshkey_with_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081,http://127.0.0.1:19006,http://192.168.*:*,http://10.0.*:*,exp://*
CAMARA_BASE_URL=https://dadosabertos.camara.leg.br/api/v2
AGGREGATES_CACHE_TTL_SECONDS=1800

{
  "name": "projeto-gasto-politico-backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": "20.x"
  },
  "volta": {
    "node": "20.18.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "dev:docker": "docker compose up --build",
    "logs:docker": "docker compose logs -f api",
    "prisma:migrate:docker": "docker compose run --rm -e RUN_MIGRATIONS=false api npm run prisma:migrate",
    "prisma:generate:docker": "docker compose run --rm -e RUN_MIGRATIONS=false -e WAIT_FOR_DB=false -e WAIT_FOR_REDIS=false api npm run prisma:generate",
    "db:reset:docker": "docker compose run --rm -e RUN_MIGRATIONS=false api npx prisma migrate reset --force --skip-generate",
    "seed:docker": "docker compose run --rm -e RUN_MIGRATIONS=false api npm run prisma:seed"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.4",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}

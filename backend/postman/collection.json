{
  "info": {
    "name": "Gasto Politico API",
    "_postman_id": "7c8f78e4-2c44-4f5e-a8f7-3f9a4db8c061",
    "description": "Collection organizada por pastas para API de gastos de deputados.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3333" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userName", "value": "User Test" },
    { "key": "userEmail", "value": "user@test.com" },
    { "key": "userPassword", "value": "Senha1234" },
    { "key": "newPassword", "value": "Senha12345" },
    { "key": "deputadoId", "value": "204379" },
    { "key": "ano", "value": "2025" },
    { "key": "mes", "value": "1" },
    { "key": "pagina", "value": "1" },
    { "key": "itens", "value": "50" },
    { "key": "limit", "value": "50" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"{{userName}}\",\"email\":\"{{userEmail}}\",\"password\":\"{{userPassword}}\"}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.success && json.data && json.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "} else {",
                  "  pm.collectionVariables.unset('accessToken');",
                  "  pm.collectionVariables.unset('refreshToken');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{userEmail}}\",\"password\":\"{{userPassword}}\"}"
            }
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/users/me"
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\"name\":\"User Updated\",\"email\":\"user.updated@test.com\"}"
            }
          }
        },
        {
          "name": "Update Password",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/users/me/password",
            "body": {
              "mode": "raw",
              "raw": "{\"currentPassword\":\"{{userPassword}}\",\"newPassword\":\"{{newPassword}}\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.success) {",
                  "  pm.collectionVariables.set('userPassword', pm.collectionVariables.get('newPassword'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Set Password Back (Optional)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/users/me/password",
            "body": {
              "mode": "raw",
              "raw": "{\"currentPassword\":\"{{userPassword}}\",\"newPassword\":\"Senha1234\"}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json && json.success) {",
                  "  pm.collectionVariables.set('userPassword', 'Senha1234');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Me",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\"password\":\"{{userPassword}}\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Deputados",
      "item": [
        {
          "name": "List Deputados",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/deputados?pagina={{pagina}}&itens={{itens}}"
          }
        },
        {
          "name": "Detail Deputado",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/deputados/{{deputadoId}}"
          }
        },
        {
          "name": "Sync Deputados",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/deputados/sync"
          }
        }
      ]
    },
    {
      "name": "Despesas",
      "item": [
        {
          "name": "Tipos de Despesa",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/despesas/tipos"
          }
        },
        {
          "name": "List Despesas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/deputados/{{deputadoId}}/despesas?ano={{ano}}&mes={{mes}}&pagina={{pagina}}&itens={{itens}}"
          }
        },
        {
          "name": "Sync Despesas",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/deputados/{{deputadoId}}/despesas/sync?ano={{ano}}&mes={{mes}}"
          }
        }
      ]
    },
    {
      "name": "Ranking",
      "item": [
        {
          "name": "Ranking CEAP",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/ranking/ceap?ano={{ano}}&mes={{mes}}&limit={{limit}}"
          }
        },
        {
          "name": "Ranking CECAP",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/ranking/cecap?ano={{ano}}&mes={{mes}}&limit={{limit}}"
          }
        }
      ]
    },
    {
      "name": "Favoritos",
      "item": [
        {
          "name": "List Favoritos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/favoritos"
          }
        },
        {
          "name": "Add Favorito",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/api/favoritos",
            "body": {
              "mode": "raw",
              "raw": "{\"deputyId\":{{deputadoId}}}"
            }
          }
        },
        {
          "name": "Delete Favorito",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/favoritos/{{deputadoId}}"
          }
        }
      ]
    }
  ]
}
